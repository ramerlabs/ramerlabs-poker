generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RoomType {
  FREE
  REAL
}

enum RoomStatus {
  WAITING
  ACTIVE
  CLOSED
}

enum TransactionGateway {
  USDT
  GCASH
  COUPON
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BONUS
}

enum CouponKind {
  CREDITS
  CASH
}

enum ClubTransferKind {
  ASSIGN
  RETURN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SeatStatus {
  SEATED
  FOLDED
  ALL_IN
  SITTING_OUT
}

enum TicketCategory {
  ACCOUNT
  BILLING
  GAMEPLAY
  TECHNICAL
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String?
  passwordHash      String
  role              UserRole       @default(USER)
  creditsBalance    Decimal        @default(1000) @db.Decimal(18, 2)
  realMoneyBalance  Decimal        @default(0) @db.Decimal(18, 2)
  currentCurrency   String         @default("USD")
  /// AES-encrypted TOTP secret (enabled only when totpEnabled is true).
  totpSecret        String?
  /// Pending secret while user confirms setup with a code.
  totpTempSecret    String?
  totpEnabled       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  roomsCreated      Room[]         @relation("RoomCreator")
  roomSeats         RoomPlayer[]
  waitlistEntries   RoomWaitlist[]
  transactions      Transaction[]
  supportTickets    SupportTicket[]
  supportMessages   SupportMessage[]
  roomChats         RoomChatMessage[]
  couponsCreated    Coupon[]        @relation("CouponCreator")
  couponClaims      CouponClaim[]
  ownedClub         Club?
  clubMemberships   ClubClient[]
  clubTransfersSent ClubTransfer[]      @relation("ClubTransferActor")
  clubTransfersRecv ClubTransfer[]      @relation("ClubTransferRecipient")

  @@index([email])
}

model Room {
  id          String         @id @default(cuid())
  name        String
  type        RoomType
  currency    String
  buyIn       Decimal        @db.Decimal(18, 2)
  smallBlind  Decimal        @db.Decimal(18, 2)
  bigBlind    Decimal        @db.Decimal(18, 2)
  /// Platform fee % taken from each REAL pot (0 for FREE rooms).
  rakePercent Decimal        @default(0) @db.Decimal(5, 2)
  /// Max rake per hand in table currency (0 = no cap).
  rakeCap     Decimal        @default(0) @db.Decimal(18, 2)
  maxPlayers  Int            @default(8)
  /// Target number of bots to keep seated (admin-configured).
  targetBots  Int            @default(0)
  /// Bot skill / planning strength 0–100 (50 = balanced). Affects hand reading & bluffs.
  botSkillPercent Int        @default(50)
  /// When false, seated players cannot send table chat.
  chatEnabled     Boolean    @default(true)
  inviteCode      String?    @unique
  isPrivate   Boolean        @default(false)
  status      RoomStatus     @default(WAITING)
  creatorId   String
  creator     User           @relation("RoomCreator", fields: [creatorId], references: [id])
  clubId      String?
  club        Club?          @relation(fields: [clubId], references: [id], onDelete: SetNull)
  players     RoomPlayer[]
  waitlist    RoomWaitlist[]
  gameState   GameState?
  rakeEvents  RakeEvent[]
  chatMessages RoomChatMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([type, status])
  @@index([inviteCode])
  @@index([clubId])
}

/// Club run by one owner. Only club owners may create tables; only admins assign owners.
model Club {
  id        String   @id @default(cuid())
  name      String
  /// One club per owner.
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Free credits the owner can assign to clients (funded by admin).
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  /// Real/cash credits the owner can assign to clients (funded by admin).
  realBalance Decimal @default(0) @db.Decimal(18, 2)
  active    Boolean  @default(true)
  rooms     Room[]
  clients   ClubClient[]
  transfers ClubTransfer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

/// Players managed by a club owner (created or linked by the owner).
model ClubClient {
  id               String   @id @default(cuid())
  clubId           String
  userId           String
  /// Club free-credit wallet (separate from User.creditsBalance).
  creditsBalance   Decimal  @default(0) @db.Decimal(18, 2)
  /// Club real/cash wallet (separate from User.realMoneyBalance).
  realMoneyBalance Decimal  @default(0) @db.Decimal(18, 2)
  note             String?
  createdAt        DateTime @default(now())
  club             Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@index([clubId, createdAt])
}

/// Ledger when credits move between club balance and a client.
model ClubTransfer {
  id          String           @id @default(cuid())
  clubId      String
  toUserId    String
  actorId     String
  amount      Decimal          @db.Decimal(18, 2)
  /// ASSIGN = club → client; RETURN = client → club.
  kind        ClubTransferKind @default(ASSIGN)
  note        String?
  createdAt   DateTime         @default(now())
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  toUser      User             @relation("ClubTransferRecipient", fields: [toUserId], references: [id], onDelete: Cascade)
  actor       User             @relation("ClubTransferActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
  @@index([toUserId, createdAt])
}

model RoomWaitlist {
  id            String   @id @default(cuid())
  roomId        String
  userId        String
  /// Seat the player clicked; filled on the next hand if free.
  preferredSeat Int?
  /// Chosen buy-in for when the waiter is seated (defaults to room minimum).
  buyInAmount   Decimal? @db.Decimal(18, 2)
  /// Heartbeat — stale waiters are removed.
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId, createdAt])
  @@index([roomId, lastSeenAt])
}

model PlatformSettings {
  id                 String  @id @default("default")
  defaultRakePercent Decimal @default(5) @db.Decimal(5, 2)
  defaultRakeCap     Decimal @default(3) @db.Decimal(18, 2)
  /// Aggregated house earnings by currency code -> balance
  houseBalances      Json    @default("{}")
  /// Site-wide cash currency (USD, PHP, …). All real-money txs use this.
  globalCurrency     String  @default("USD")
  /// When false, force polling even if an Ably key is configured.
  ablyEnabled        Boolean @default(true)
  /// Optional Ably API key stored by admin (falls back to env ABLY_API_KEY).
  ablyApiKey         String?
  updatedAt          DateTime @updatedAt
}

model RakeEvent {
  id         String   @id @default(cuid())
  roomId     String
  handNumber Int
  amount     Decimal  @db.Decimal(18, 2)
  currency   String
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([roomId])
}

model RoomPlayer {
  id           String     @id @default(cuid())
  roomId       String
  userId       String
  seat         Int
  stack        Decimal    @db.Decimal(18, 2)
  status       SeatStatus @default(SEATED)
  /// Set when the client disconnects mid-hand; cashed out after the hand.
  pendingLeave Boolean    @default(false)
  /// Heartbeat — stale humans are auto-disconnected.
  lastSeenAt   DateTime   @default(now())
  joinedAt     DateTime   @default(now())
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@unique([roomId, seat])
  @@index([userId])
  @@index([roomId, lastSeenAt])
}

/// Short-lived table chat — bubbles beside seats; pruned after a few seconds.
model RoomChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  seat      Int
  text      String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId, createdAt])
}

model Transaction {
  id          String              @id @default(cuid())
  userId      String
  amount      Decimal             @db.Decimal(18, 2)
  currency    String
  gateway     TransactionGateway
  type        TransactionType
  status      TransactionStatus   @default(PENDING)
  reference   String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model GameState {
  id        String   @id @default(cuid())
  roomId    String   @unique
  version   Int      @default(1)
  state     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model CurrencyConfig {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  enabled         Boolean  @default(true)
  usdtAddress     String?
  gcashMerchantId String?
  minDeposit      Decimal  @default(10) @db.Decimal(18, 2)
  minWithdrawal   Decimal  @default(10) @db.Decimal(18, 2)
  paymentParams   Json?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  category  TicketCategory
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportMessage[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
  @@index([priority])
  @@index([category])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  isStaff   Boolean       @default(false)
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorId])
}

/// Key/value settings (e.g. site-wide license state for RamerLabs License Manager).
model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Admin-generated promo codes for free credits or real cash.
model Coupon {
  id          String      @id @default(cuid())
  code        String      @unique
  kind        CouponKind
  amount      Decimal     @db.Decimal(18, 2)
  /// Required for CASH coupons (e.g. USD, PHP). Unused for CREDITS.
  currency    String?
  /// Total times this code can be claimed across all users.
  maxClaims   Int         @default(1)
  claimCount  Int         @default(0)
  expiresAt   DateTime?
  active      Boolean     @default(true)
  note        String?
  createdById String
  createdBy   User        @relation("CouponCreator", fields: [createdById], references: [id])
  claims      CouponClaim[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([active, createdAt])
  @@index([kind])
}

model CouponClaim {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId, createdAt])
}
