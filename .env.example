DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
# Optional realtime. Leave key empty or set ABLY_ENABLED=false to use polling.
ABLY_API_KEY=""
ABLY_ENABLED="true"
NEXT_PUBLIC_APP_NAME="RamerLabs Poker"

# License (RamerLabs License Manager) — site-wide gate
